const CATEGORIES = [...new Set(PRODUITS.map(p => p.categorie))];

/* ========= Recherche & Filtres================== */

let categorieActive = "toutes";
let indexLightbox = 0;
let produitsAffiches = [];

function construireBoutonsCategories(){
  const conteneur = document.getElementById('filtresCategories');
  const boutons = ["toutes", ...CATEGORIES].map(cat => {
    const label = cat === "toutes" ? "Tous les produits" : cat;
    return `<button class="filtre-cat" data-cat="${cat}">${label}</button>`;
  }).join('');
  conteneur.innerHTML = boutons;
  conteneur.querySelectorAll('.filtre-cat').forEach(btn => {
    btn.addEventListener('click', () => {
      categorieActive = btn.dataset.cat;
      conteneur.querySelectorAll('.filtre-cat').forEach(b => b.classList.remove('actif'));
      btn.classList.add('actif');
      filtrerEtAfficher();
    });
  });
  conteneur.querySelector('[data-cat="toutes"]').classList.add('actif');
}

function filtrerEtAfficher(){
  const champRecherche = document.getElementById('rechercheProduit');
  const terme = champRecherche ? champRecherche.value.trim().toLowerCase() : "";
  produitsAffiches = PRODUITS.filter(p => {
    const correspondCategorie = categorieActive === "toutes" || p.categorie === categorieActive;
    const correspondRecherche = p.nom.toLowerCase().includes(terme) ||
                                 p.categorie.toLowerCase().includes(terme) ||
                                 p.vendeur.toLowerCase().includes(terme);
    return correspondCategorie && correspondRecherche;
  });
  afficherProduits(produitsAffiches);
}

function afficherProduits(liste){
  const grille = document.getElementById('grilleProduits');
  const messageVide = document.getElementById('messageAucunProduit');
  if(liste.length === 0){
    grille.innerHTML = '';
    messageVide.style.display = 'block';
    return;
  }
  messageVide.style.display = 'none';
  grille.innerHTML = liste.map((p, i) => `
    <article class="carte-produit">
      <div class="vignette-produit" style="background:${p.couleur}" onclick="ouvrirLightbox(${i})"><span>${p.emoji}</span></div>
      <div class="corps-produit">
        <span class="badge-categorie">${p.categorie}</span>
        <h3>${p.nom}</h3>
        <p class="desc-produit">${p.description}</p>
        <div class="ligne-prix"><strong>${p.prix}</strong><span class="vendeur">${p.vendeur}</span></div>
      </div>
    </article>
  `).join('');
}

/* ---- Galerie / Lightbox (Personne 3) ---- */
function ouvrirLightbox(index){ indexLightbox = index; majLightbox(); document.getElementById('lightbox').classList.add('ouvert'); }
function fermerLightbox(){ document.getElementById('lightbox').classList.remove('ouvert'); }
function lightboxSuivant(){ indexLightbox = (indexLightbox + 1) % produitsAffiches.length; majLightbox(); }
function lightboxPrecedent(){ indexLightbox = (indexLightbox - 1 + produitsAffiches.length) % produitsAffiches.length; majLightbox(); }
function majLightbox(){
  const p = produitsAffiches[indexLightbox];
  if(!p) return;
  document.getElementById('lightboxVisuel').style.background = p.couleur;
  document.getElementById('lightboxEmoji').textContent = p.emoji;
  document.getElementById('lightboxCategorieBadge').textContent = p.categorie;
  document.getElementById('lightboxNom').textContent = p.nom;
  document.getElementById('lightboxDesc').textContent = p.description;
  document.getElementById('lightboxPrix').textContent = p.prix;
  document.getElementById('lightboxVendeur').textContent = p.vendeur;
}

/* ========Mode sombre =================== */
function appliquerModeSombre(actif){
  document.body.classList.toggle('mode-sombre', actif);
  const bouton = document.getElementById('toggleSombre');
  bouton.textContent = actif ? '☀️ Mode clair' : '🌙 Mode sombre';
  localStorage.setItem('achetons_bf_mode_sombre', actif ? '1' : '0');
}

/* ===============Navigation entre pages (fichier unique)================= */
function allerA(nomPage){
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + nomPage).classList.add('active');
  document.querySelectorAll('.lien-nav').forEach(b => b.classList.toggle('actif', b.dataset.page === nomPage));
  window.scrollTo({top:0, behavior:'smooth'});
  if(nomPage === 'produits' && document.getElementById('grilleProduits').innerHTML === ''){
    construireBoutonsCategories();
    filtrerEtAfficher();
  }
}

/* ===========Contact vendeur & Intégration finale=============== */
function remplirSelectProduits(){
  const select = document.getElementById('produitConcerne');
  PRODUITS.forEach(p => {
    const option = document.createElement('option');
    option.value = p.nom;
    option.textContent = `${p.nom} — ${p.vendeur}`;
    select.appendChild(option);
  });
}
function validerChamp(id, condition){
  const champ = document.getElementById(id);
  champ.classList.toggle('invalide', !condition);
  return condition;
}

document.addEventListener('DOMContentLoaded', () => {
  // Mode sombre : préférence sauvegardée
  const prefSombre = localStorage.getItem('achetons_bf_mode_sombre') === '1';
  appliquerModeSombre(prefSombre);
  document.getElementById('toggleSombre').addEventListener('click', () => {
    appliquerModeSombre(!document.body.classList.contains('mode-sombre'));
  });

  // Recherche produits
  document.getElementById('rechercheProduit').addEventListener('input', filtrerEtAfficher);

  // Contact
  remplirSelectProduits();
  document.getElementById('formContact').addEventListener('submit', function(e){
    e.preventDefault();
    const nom = document.getElementById('nom').value.trim();
    const contactInfo = document.getElementById('contactInfo').value.trim();
    const produit = document.getElementById('produitConcerne').value;
    const message = document.getElementById('messageTexte').value.trim();

    const regexTelephone = /^[0-9\s+]{8,}$/;
    const regexEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const contactValide = regexTelephone.test(contactInfo) || regexEmail.test(contactInfo);

    const nomOk = validerChamp('champNom', nom.length >= 2);
    const contactOk = validerChamp('champContact', contactValide);
    const produitOk = validerChamp('champProduit', produit !== '');
    const messageOk = validerChamp('champMessage', message.length >= 10);

    const messageConfirmation = document.getElementById('messageConfirmation');
    if(nomOk && contactOk && produitOk && messageOk){
      messageConfirmation.style.display = 'block';
      this.reset();
      document.querySelectorAll('.champ').forEach(c => c.classList.remove('invalide'));
      messageConfirmation.scrollIntoView({behavior:'smooth', block:'center'});
    } else {
      messageConfirmation.style.display = 'none';
    }
  });

  // Chargement initial de la page produits
  construireBoutonsCategories();
  filtrerEtAfficher();
});
